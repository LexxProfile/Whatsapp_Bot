"GOOGLE_API_KEY\"]},\"base_url\":\"https://generativelanguage.googleapis.com\",\"model\":\"gemini-flash-latest\"},\"response\":{\"response\":{\"generations\":[[{\"text\":\"{\\n  \\\"nomor_sparepart\\\": \\\"802000277AA\\\",\\n  \\\"nama_sparepart\\\": \\\"TIRE PRESSURE SENSOR\\\",\\n  \\\"harga_jual_inc_tax\\\": \\\"Rp 397.713\\\",\\n  \\\"harga_jual_exc_tax\\\": \\\"Rp 358.300\\\",\\n  \\\"Tipe Mobil Tersedia\\\": [\\n    \\\"Omoda 5 RZ\\\",\\n    \\\"OMODA 5 Z\\\",\\n    \\\"OMODA 5GT FWD\\\",\\n    \\\"OMODA 5GT AWD\\\",\\n    \\\"OMODA 5 EV\\\",\\n    \\\"TIGGO CROSS\\\",\\n    \\\"TIGGO 8 CSH\\\",\\n    \\\"C5 RZ\\\",\\n    \\\"C5 Z\\\"\\n  ]\\n}\",\"generationInfo\":{\"index\":0,\"finishReason\":\"STOP\"}}]]},\"tokenUsage\":{\"completionTokens\":68,\"promptTokens\":0,\"totalTokens\":68}}}"}}
