com\",\"model\":\"gemini-flash-latest\"},\"response\":{\"response\":{\"generations\":[[{\"text\":\"{\\n  \\\"nomor_sparepart\\\": \\\"301002516AA\\\",\\n  \\\"nama_sparepart\\\": \\\"TEMPERATURE＆PRESSURE SENSOR (LOW PRESSUR\\\",\\n  \\\"harga_jual_inc_tax\\\": \\\"Rp -\\\",\\n  \\\"harga_jual_exc_tax\\\": \\\"Rp -\\\",\\n  \\\"Tipe Mobil Tersedia\\\": [\\n    \\\"J6 IWD\\\",\\n    \\\"J6 RWD\\\"\\n  ]\\n}\",\"generationInfo\":{\"index\":0,\"finishReason\":\"STOP\"}}]]},\"tokenUsage\":{\"completionTokens\":56,\"promptTokens\":0,\"totalTokens\":56}}}"}}
